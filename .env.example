# Trello "API Key" + "OAuth Secret" from https://trello.com/app-key
# These identify the application; per-user tokens are obtained via auth_login.
TRELLO_CONSUMER_KEY=
TRELLO_CONSUMER_SECRET=

# Display name shown to the user during the OAuth consent screen.
TRELLO_APP_NAME="Trello MCP Connector"

# Optional override for token store location (defaults to ~/.trello-connector).
# TRELLO_CONNECTOR_HOME=

# Fixed local port for the OAuth callback. Must match an entry under
# "Allowed Origins" on https://trello.com/app-key (e.g.
# http://127.0.0.1:51823) — Trello no longer accepts the `*` wildcard.
TRELLO_OAUTH_CALLBACK_PORT=51823

# Port for the standalone webhook receiver (trello-webhook-server).
TRELLO_WEBHOOK_PORT=4567
